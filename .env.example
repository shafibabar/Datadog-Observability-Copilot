# Copy this file to ".env" and fill in your values for the demo.
# The real ".env" is gitignored and is NEVER committed. Leave this template empty.
#
#   cp .env.example .env      (then edit .env)

# --- Reasoning layer: how the app talks to Claude ---
# Two ways to run — you only need ONE:
#
#   (A) The "Claude Code" way (NO API key). If you have the `claude` CLI
#       installed and signed in (you're using it right now), leave everything
#       in this section blank. The app shells out to your local Claude Code
#       login. This is the default when no API key is set.
#
#   (B) The Anthropic API key way. Get a key at
#       https://console.anthropic.com/ -> Settings -> API Keys, and paste it here:
ANTHROPIC_API_KEY=

# Backend selection: "auto" (default: Claude CLI when no key above, else the API),
# "cli" (always use the Claude Code CLI), or "sdk" (always use the API key).
COPILOT_LLM_BACKEND=auto

# Model selection (cost-conscious defaults). Override only if you want.
# Cheaper model used for routine extraction/classification passes:
COPILOT_MODEL_FAST=claude-haiku-4-5-20251001
# Stronger model used for the main reasoning/narrative:
COPILOT_MODEL_DEEP=claude-sonnet-4-6

# --- Datadog (live data source — OPTIONAL) ---
# Leave blank to run on the replayed demo incident only.
#
# Preferred: a Personal Access Token (PAT) — a single standalone credential.
# Create one at: Datadog -> (your avatar) Personal Settings -> Access Tokens
#   -> "+ New Access Token" -> name it, set an expiry, grant read scopes, copy once.
DATADOG_ACCESS_TOKEN=
#
# Legacy alternative (still works, now considered legacy): API key + Application key.
#   https://app.datadoghq.com/organization-settings/api-keys          (API key)
#   https://app.datadoghq.com/organization-settings/application-keys  (Application key)
DATADOG_API_KEY=
DATADOG_APP_KEY=
# Your Datadog site/region (datadoghq.com, datadoghq.eu, us3.datadoghq.com, ...):
DATADOG_SITE=datadoghq.com
#
# Scope dropdowns (Environment / Tenant / Duration):
#   "env" is Datadog's standard environment tag. "tenant" is NOT a native Datadog
#   concept, so tell the app which tag key represents your tenant (e.g. tenant,
#   customer, account, org):
DATADOG_TENANT_TAG=tenant
#   A widely-emitted metric the app queries ONLY to list distinct env/tenant tag
#   values for the dropdowns. It must be a metric that actually carries those tags
#   in your org (e.g. a trace or system metric). Adjust if the dropdowns come up empty:
DATADOG_DISCOVERY_METRIC=system.cpu.user

# --- App ---
# Which data source the app starts with: "replay" (scripted demo) or "datadog" (live).
# >>> To use your real Datadog org, set this to: datadog
COPILOT_DATA_SOURCE=replay
# Where the Investigation Workspace database is stored (gitignored). Optional.
COPILOT_WORKSPACE_DB=data/workspace.db
