# Secrets — NEVER commit. Real keys live only in a local .env (see .env.example).
.env
.env.*
!.env.example
*.key
*.pem
secrets/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.venv*/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Local workspace state / databases
*.db
*.sqlite
*.sqlite3
data/*.db

# Metrics collector local runtime state (the prompts.jsonl data IS committed)
metrics/.collector_state.json

# Claude Code: commit the shared hook (settings.json); keep personal overrides local
.claude/settings.local.json

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Windows Zone.Identifier files (WSL)
*:Zone.Identifier
